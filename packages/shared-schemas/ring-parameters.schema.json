{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jewelryai.local/schemas/ring-parameters.schema.json",
  "title": "RingParameters",
  "type": "object",
  "required": ["band_thickness_mm", "gemstone_type", "gemstone_size_mm", "metal"],
  "properties": {
    "band_thickness_mm": { "type": "number", "minimum": 1.2, "maximum": 5.0 },
    "gemstone_type": {
      "type": "string",
      "enum": ["diamond", "ruby", "emerald", "sapphire"]
    },
    "gemstone_size_mm": { "type": "number", "minimum": 1.0, "maximum": 12.0 },
    "metal": {
      "type": "string",
      "enum": ["gold", "rose_gold", "platinum", "silver"]
    }
  },
  "additionalProperties": false
}
